        char nb[4096] = {0};
        struct nlmsghdr *nlh = (struct nlmsghdr*)nb;
        nlh->nlmsg_type = XFRM_MSG_NEWSA;
        nlh->nlmsg_flags = NLM_F_REQUEST | NLM_F_ACK;
        nlh->nlmsg_len = NLMSG_LENGTH(sizeof(struct xfrm_usersa_info));
